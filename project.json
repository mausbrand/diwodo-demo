{
    "cli-version": "2.2.1",
    "default": {
        "application_name": "diwodo-demo-viur3",
        "builds": {
            "admin": {
                "clean": "rm -rf deploy/admin",
                "command": "viur package install admin 4.14.4",
                "kind": "exec",
                "version": "4.14.4"
            },
            "app": {
                "command": "build",
                "kind": "npm",
                "source": "app"
            },
            "site": {
                "command": "build",
                "kind": "npm",
                "source": "site"
            }
        },
        "distribution_folder": "./deploy",
        "sources_folder": "./sources",
        "version": "$(year)-$(month)-$(day)-$(user)-dev"
    },
    "format": "2.0.0"
}
